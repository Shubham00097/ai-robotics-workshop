# server/.env.example
# Copy this file to .env and fill in the values before running locally or deploying.

# Port the Express server listens on (Render sets this automatically)
PORT=5000

# Node environment — set to 'production' when deploying
NODE_ENV=development

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbName>?retryWrites=true&w=majority
# Leave empty to run without a database (submissions are logged to the console as fallback)
MONGO_URI=

# Allowed frontend origin for CORS (only needed when deploying frontend & backend separately)
# Example: https://my-workshop.vercel.app
FRONTEND_URL=
